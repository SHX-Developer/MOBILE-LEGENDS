{
    email {$LETSENCRYPT_EMAIL}
    admin off
}

{$DOMAIN} {
    encode zstd gzip

    @api path /api/*
    handle @api {
        reverse_proxy server:3000 {
            health_uri /api/healthz
            health_interval 15s
            health_timeout 3s
        }
    }

    handle {
        reverse_proxy web:80
    }

    log {
        output stdout
        format console
    }
}

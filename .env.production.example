# ─────────────────────────────────────────────────────────────────────
# Copy to .env on the VPS:  cp .env.production.example .env
# ─────────────────────────────────────────────────────────────────────

# Public domain pointing to this VPS (A-record). Required for HTTPS.
DOMAIN=play.example.com

# Email used by Caddy for Let's Encrypt notifications (optional).
LETSENCRYPT_EMAIL=you@example.com

# Postgres credentials (used by db + server).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-pass
POSTGRES_DB=ml_moba

# Telegram bot token from @BotFather. Empty = signature checks skipped (dev only).
TELEGRAM_BOT_TOKEN=

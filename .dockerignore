# keep build context tiny + cache-friendly
**/node_modules
**/dist
**/build
**/coverage
**/.cache
**/.turbo
**/.next

# editor / OS
.git
.github
.idea
.vscode
.DS_Store
Thumbs.db

# env / secrets — never bake into image
.env
.env.*
!.env.production.example
**/.env
**/.env.*
!**/.env.example

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# misc
package-lock.json
yarn.lock
README.md
DEPLOY.md
LICENSE
docs

# docker meta
docker-compose*.yml
compose*.yml
Dockerfile
**/Dockerfile
.dockerignore
